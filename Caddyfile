# Production reverse proxy (V3-4-1/V3-4-2). Caddy issues and renews the
# HTTPS certificate for soulmatch.redprana.com automatically via Let's
# Encrypt once DNS resolves to this server — no manual cert steps.
#
# [HUMAN]: point a GoDaddy DNS A record for `soulmatch` at this server's
# public IP before starting this stack (see docs/DEPLOY.md) — Caddy will
# fail its first cert request until DNS resolves.

soulmatch.redprana.com {
	# Link-preview crawlers (WhatsApp, Facebook, Twitter/X, LinkedIn, Slack,
	# Telegram) can't read Streamlit's client-rendered <title>/meta tags, so
	# a shared link showed the generic "Streamlit" preview. Serve those
	# crawlers a static page with proper Open Graph tags instead; everyone
	# else still gets proxied straight to the app. Must be matched before
	# the catch-all reverse_proxy below.
	@social_crawlers header_regexp User-Agent (?i)(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest)
	handle @social_crawlers {
		root * /srv/social-preview
		file_server
	}

	# The Open Graph image itself, referenced by absolute URL from the
	# crawler preview page above — served for everyone, not just bots,
	# since crawlers fetch it as a follow-up request after the HTML.
	handle /og-image.png {
		root * /srv/social-preview
		file_server
	}

	# Payment-gateway webhooks (Razorpay/Stripe) go to the sidecar, not the
	# Streamlit app — must be matched before the catch-all reverse_proxy below.
	handle /webhooks/* {
		reverse_proxy webhooks:8502
	}

	handle {
		reverse_proxy app:8501 {
			# Streamlit's websocket connection needs these headers forwarded,
			# or the app silently fails to establish a session.
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}
}
