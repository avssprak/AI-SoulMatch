# Copy to .env and fill in what you have. Everything has a working default.

# Database (SQLite by default; switch to PostgreSQL later, e.g.
# postgresql+psycopg://user:pass@localhost/soulmatch)
DATABASE_URL=sqlite:///data/soulmatch.db

# LLM provider for profile extraction: mock | gemini | anthropic | local
LLM_PROVIDER=mock

# Google AI Studio free-tier key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic key (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# local — any OpenAI-compatible chat-completions server on this machine/network
# (LM Studio, Ollama, etc.), no API key needed
LOCAL_LLM_URL=http://localhost:1234/v1/chat/completions
LOCAL_LLM_MODEL=google/gemma-3-1B-it-QAT

# First-run admin account, auto-created if the users table is empty.
# Set these BEFORE first run if you don't want the default password;
# otherwise change it immediately after first login (sidebar -> Change password,
# or Users page -> Reset password).
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# --- Billing (V3-3) ----------------------------------------------------------
# Base URL the app is served at — used to build Stripe checkout success/cancel
# redirects. Set to https://soulmatch.redprana.com in production.
APP_BASE_URL=http://localhost:8501
# Port the webhook sidecar (webhook_server.py) listens on. In production,
# Caddy proxies https://soulmatch.redprana.com/webhooks/* to this port.
WEBHOOK_SERVER_PORT=8502

# Razorpay (INR, UPI Autopay). [HUMAN]: create the account at
# https://dashboard.razorpay.com, create 4 recurring Plans (Plus/Pro x
# monthly/annual) under Subscriptions, and set up a webhook endpoint pointed
# at /webhooks/razorpay subscribed to subscription.activated/.charged/
# .halted/.cancelled — the dashboard gives you the webhook secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PLUS_MONTHLY=
RAZORPAY_PLAN_PLUS_ANNUAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=

# Stripe (USD, for NRI customers). [HUMAN]: create the account at
# https://dashboard.stripe.com, create 4 recurring Prices (Plus/Pro x
# monthly/annual), and add a webhook endpoint pointed at /webhooks/stripe
# subscribed to checkout.session.completed/invoice.paid/
# invoice.payment_failed/customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
